  - CharacterName: "\u0425\u043E\u0437\u044F\u0438\u043D \u0416\u0430\u0440\u0438\u043D"
    CharacterLine: "\u041C\u0423\u0410\u0425\u0410\u0425\u0410\u0425\u0410\u0425"
    sprite: {fileID: 21300000, guid: d87906a19f89202449eecc7dacd1446a, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0425\u043E\u0437\u044F\u0438\u043D \u0416\u0430\u0440\u0438\u043D"
    CharacterLine: "\u0437\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439,
      \u041D\u0435\u0434\u043E\u0441\u0442\u043E\u0439\u043D\u044B\u0439. \u0447\u0442\u043E
      \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u0442\u0435\u0431\u044F \u0432\u043E
      \u0432\u043B\u0430\u0434\u0435\u043D\u0438\u044F \u0441\u0430\u043C\u043E\u0433\u043E
      \u0425\u043E\u0437\u044F\u0438\u043D \u0416\u0430\u0440\u0438\u043D\u0430?"
    sprite: {fileID: 21300000, guid: d87906a19f89202449eecc7dacd1446a, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0425\u043E\u0437\u044F\u0438\u043D \u0416\u0430\u0440\u0438\u043D"
    CharacterLine: "\u0442\u044B \u0445\u043E\u0447\u0435\u0448\u044C \u043D\u0430\u0443\u0447\u0438\u0442\u044C\u0441\u044F
      \u043F\u0440\u043E\u0436\u0430\u0440\u0438\u0432\u0430\u0442\u044C \u043B\u0430\u0432\u0430\u043D\u0434\u0443?
      \u0430 \u0436\u0430\u0440\u0435\u043D\u044B\u0445 \u0431\u043E\u0431\u043E\u0432
      \u043D\u0435 \u0445\u043E\u0447\u0435\u0448\u044C?"
    sprite: {fileID: 21300000, guid: d87906a19f89202449eecc7dacd1446a, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0425\u043E\u0437\u044F\u0438\u043D \u0416\u0430\u0440\u0438\u043D"
    CharacterLine: ....
    sprite: {fileID: 21300000, guid: d87906a19f89202449eecc7dacd1446a, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0425\u043E\u0437\u044F\u0438\u043D \u0416\u0430\u0440\u0438\u043D"
    CharacterLine: "\u041A\u0445-\u043A\u0445. \u0422\u044B \u043D\u0435 \u0433\u0440\u0443\u0431\u0438\u0448\u044C
      \u043C\u043D\u0435 \u0438 \u043D\u0435 \u0437\u0430\u0434\u0430\u0435\u0448\u044C
      \u0433\u043B\u0443\u043F\u044B\u0445 \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u0432.
      \u041C\u043E\u043B\u043E\u0434\u0435\u0446."
    sprite: {fileID: 21300000, guid: d87906a19f89202449eecc7dacd1446a, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0425\u043E\u0437\u044F\u0438\u043D \u0416\u0430\u0440\u0438\u043D"
    CharacterLine: "\u0412\u0435\u043B\u0438\u043A\u0438\u0439 \u0425\u043E\u0437\u044F\u0438\u043D
      \u0416\u0430\u0440\u0438\u043D \u0441\u043E\u0438\u0437\u0432\u043E\u043B\u0438\u0442
      \u043F\u043E\u043C\u043E\u0447\u044C \u0442\u0435\u0431\u0435 \u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C
      \u041D\u0410\u0421\u0422\u041E\u042F\u0429\u0415\u0415 \u041C\u0410\u0421\u0422\u0415\u0420\u0421\u0422\u0412\u041E
      \u041F\u0420\u0418\u0413\u041E\u0422\u041E\u0412\u041B\u0415\u041D\u0418\u042F
      \u041B\u0410\u0412\u0410\u041D\u0414\u041E\u0412\u041E\u0413\u041E \u0420\u0410\u0424\u0410"
    sprite: {fileID: 21300000, guid: d87906a19f89202449eecc7dacd1446a, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0425\u043E\u0437\u044F\u0438\u043D \u0416\u0430\u0440\u0438\u043D"
    CharacterLine: "..\u0442\u043E\u043B\u044C\u043A\u043E \u044D\u0442\u043E. \u0435\u0441\u043B\u0438
      \u0437\u0430\u043F\u0430\u0445\u043D\u0435\u0442 \u043A\u0443\u0440\u043E\u0439-\u0433\u0440\u0438\u043B\u044C
      \u043D\u0435 \u0441\u043C\u0443\u0449\u0430\u0439\u0441\u044F, \u043B\u0430\u0434\u043D\u043E?"
    sprite: {fileID: 21300000, guid: d87906a19f89202449eecc7dacd1446a, type: 3}
