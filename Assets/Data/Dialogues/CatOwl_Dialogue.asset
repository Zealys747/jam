  lines:
  - CharacterName: "\u0421\u0438\u0436\u0443\u0445"
    CharacterLine: "\u043E \u0435\u043F\u0442\u0430, \u043F\u0440\u0438\u0432\u0435\u0442."
    sprite: {fileID: 21300000, guid: 7e44ec65f0d8c3647af684c36b9df7cb, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0421\u0438\u0436\u0443\u0445"
    CharacterLine: "..\u043C\u0435\u043D\u044F \u0421\u0438\u0436\u0443\u0445 \u0437\u043E\u0432\u0443\u0442."
    sprite: {fileID: 21300000, guid: 7e44ec65f0d8c3647af684c36b9df7cb, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0421\u0438\u0436\u0443\u0445"
    CharacterLine: ".. \u043D\u0443 \u0442\u044B \u043C\u043E\u043B\u0447\u0430\u043B\u0438\u0432\u044B\u0439
      \u043A\u0430\u043A\u043E\u0439-\u0442\u043E. \u041D\u0443 \u043B\u0430\u0434\u043D\u043E.
      \u041C\u043E\u043B\u0447\u0438\u0442 \u0437\u043D\u0430\u0447\u0438\u0442 \u0443\u043C\u043D\u044B\u0439."
    sprite: {fileID: 21300000, guid: 7e44ec65f0d8c3647af684c36b9df7cb, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0421\u0438\u0436\u0443\u0445"
    CharacterLine: "\u0432 \u043E\u0431\u0449\u0435\u043C, \u0442\u0443\u0442 \u0442\u0435\u043C\u043A\u0430
      \u0442\u0430\u043A\u0430\u044F. \u0442\u044B \u0436\u0435 \u0437\u043D\u0430\u0435\u0448\u044C,
      \u0447\u0442\u043E \u0442\u0430\u043A\u043E\u0435.."
    sprite: {fileID: 21300000, guid: 7e44ec65f0d8c3647af684c36b9df7cb, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0421\u0438\u0436\u0443\u0445"
    CharacterLine: "..\u041B\u0410\u0412\u0410\u041D\u0414\u041E\u0412\u042B\u0419
      \u0420\u0410\u0424????!!??!!?"
    sprite: {fileID: 21300000, guid: 7e44ec65f0d8c3647af684c36b9df7cb, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0421\u0438\u0436\u0443\u0445"
    CharacterLine: "\u0442\u0430\u043A \u0432\u043E\u0442, \u043D\u0435 \u0441\u043B\u0443\u0448\u0430\u0439
      \u0432\u0441\u0435\u0445 \u044D\u0442\u0438\u0445 \u0433\u0443\u0440\u0443
      \u0438 \u044D\u043A\u0441\u043F\u0435\u0440\u0442\u043E\u0432! \u0432\u0435\u0441\u044C
      \u0441\u0435\u043A\u0440\u0435\u0442 - \u0437\u0443\u0431 \u0434\u0430\u044E,
      \u0432 \u0417\u0415\u0420\u041D\u0410\u0425"
    sprite: {fileID: 21300000, guid: 7e44ec65f0d8c3647af684c36b9df7cb, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0421\u0438\u0436\u0443\u0445"
    CharacterLine: "\u041A\u0441\u0442\u0430\u0442\u0438, \u0437\u0435\u0440\u043D\u0430
      \u0443 \u043C\u0435\u043D\u044F \u0443\u0430\u0430\u0430\u0430\u0439 \u043A\u0430\u043A\u0438\u0435.
      \u044F \u0438\u0445 \u0441\u0430\u043C \u0432\u044B\u0440\u0430\u0449\u0438\u0432\u0430\u044E."
    sprite: {fileID: 21300000, guid: 7e44ec65f0d8c3647af684c36b9df7cb, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0421\u0438\u0436\u0443\u0445"
    CharacterLine: "\u044D\u044D \u043D\u0435\u043D\u0435\u043D\u0435 \u0441\u0442\u043E\u0439!!!
      \u044F \u0432\u0438\u0436\u0443, \u0441\u0435\u0440\u0434\u0446\u0435 \u0443
      \u0442\u0435\u0431\u044F.. \u044D\u044D.. \u0435\u0441\u0442\u044C."
    sprite: {fileID: 21300000, guid: 7e44ec65f0d8c3647af684c36b9df7cb, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0421\u0438\u0436\u0443\u0445"
    CharacterLine: "\u0430 \u0435\u0449\u0435 \u0432 \u0442\u0435\u0431\u0435 \u0435\u0441\u0442\u044C
      \u0447\u0443\u0439\u043A\u0430 \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0433\u043E
      \u043C\u0430\u0441\u0442\u0435\u0440\u0430 \u041B\u0410\u0412\u0410\u041D\u0414\u041E\u0412\u041E\u0413\u041E
      \u0420\u0410\u0424\u0410"
    sprite: {fileID: 21300000, guid: 7e44ec65f0d8c3647af684c36b9df7cb, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
  - CharacterName: "\u0421\u0438\u0436\u0443\u0445"
    CharacterLine: "\u0434\u0435\u0440\u0436\u0438 \u0441\u0435\u043C\u0435\u043D\u0430.
      \u0431\u0435\u0441\u043F\u043B\u0430\u0442\u043D\u043E. \u0441\u0434\u0435\u043B\u0430\u0439
      \u0433\u0440\u044F\u0437\u044C. \u0438\u043B\u0438 \u043A\u043E\u0444\u0435.
      \u0436\u0435\u043B\u0430\u0442\u0435\u043B\u044C\u043D\u043E."
    sprite: {fileID: 21300000, guid: 7e44ec65f0d8c3647af684c36b9df7cb, type: 3}
    delayBefore: 0.5
    typewriterSpeed: 30
    autoAdvanceDelay: 2
